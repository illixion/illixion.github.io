# Deployment configuration — edit this one file to adopt the system.
# Sourced by generate/sign-keys.sh to build the manifest, discovery.json, and
# page. (The binaries no longer bake any of this in — clients learn the location
# at runtime from discovery.json; only the signing keys are compiled in.)
# All values are shell-quoted strings.

# Public base URL where the site is served. The page, manifest, discovery.json,
# and bin/ all live under this.
export SKU_BASE_URL="https://ssh.illixion.com"

# Identity shown on the generated page / published in discovery.json.
export SKU_TITLE="Ixion"
export SKU_HANDLE="@illixion"

# Source repository — the page's source/doc links point here (GitHub) instead
# of the Pages site, so directory and Markdown links render properly.
export SKU_REPO_URL="https://github.com/illixion/illixion.github.io"

# Recommended client check cadence, published in discovery.json (clients clamp
# to [1m, 24h]). splay = max random pre-fetch delay so hosts don't sync up.
export SKU_INTERVAL="15m"
export SKU_SPLAY="15m"

# Source key list the manifest is built from (authorized_keys format: one
# "ssh-… key comment" per line; blank lines and # comments ignored). Relative
# paths are resolved against the repo root.
export SKU_SOURCE_KEYS="keys.list"
